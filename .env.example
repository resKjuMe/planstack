APP_NAME=Planstack
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Pusher (Header-Glocke / Benachrichtigungen). Key ist oeffentlich und wird im
# HTML ausgeliefert; App-ID und Secret sind geheim. Cluster i. d. R. eu.
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu
# Nur fuer lokale Windows-Umgebungen ohne CA-Bundle (cURL-Fehler 60): auf false
# setzen, um die TLS-Pruefung der Pusher-Requests abzuschalten. In Produktion true lassen.
# PUSHER_VERIFY_SSL=false

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Planstack ────────────────────────────────────────────────────────────────
# GitHub-Token (Scope "repo") für den "PRs abgleichen"-Button, der den
# Merge-Status existierender PRs von GitHub holt. Für private Repos Pflicht;
# ohne Token funktionieren nur öffentliche Repos (stark rate-limitiert).
GITHUB_TOKEN=

# GitHub-API-Basis (nur für GHE/Proxy nötig).
# GITHUB_API_URL=https://api.github.com

# TLS-Verifikation der GitHub-Calls. Default true (sicher). Notausgang für rein
# lokale Nutzung (z. B. Windows ohne CA-Bundle, cURL-Fehler 60): false — oder
# den Pfad zu einer cacert.pem angeben.
# GITHUB_VERIFY_SSL=true

# Basis-URL (inkl. /api), die in die config.json des herunterladbaren
# Planstack-Skills geschrieben wird. Default = Produktionsinstanz; für lokale Tests
# überschreiben.
# PLANSTACK_SKILL_API_URL=https://planstack.eskju.net/api
